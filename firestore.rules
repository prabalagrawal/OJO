rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check - checking the 'users' collection for the ADMIN role
    // Using simple role check for users, bootstrapping developer
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'prabalagrawal23@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
      );
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt']) && 
             data.keys().size() == 5 &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.role in ['CUSTOMER', 'VENDOR', 'ADMIN'] &&
             data.createdAt is string; 
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'origin']) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category in ["Tea", "Saree", "Handicraft", "Jewelry", "Spice"] &&
             data.origin is string && data.origin.size() <= 100 &&
             (data.get('artisanName', '') is string) &&
             (data.get('description', '') is string) &&
             (data.get('verificationStatus', 'PENDING') in ["VERIFIED", "PENDING", "FAILED"]);
    }

    function isValidCartItem(data) {
      return data.keys().hasAll(['productId', 'quantity']) &&
             data.productId is string &&
             data.quantity is number && data.quantity > 0 && data.quantity <= 100 &&
             (data.get('addedAt', request.time) == request.time);
    }

    // --- Collection Routes ---

    // Connection test document
    match /test/connection {
      allow read: if true; 
    }

    // Products Registry
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'price', 'images', 'description', 'origin', 
          'artisanName', 'story', 'category', 'decisionHelper', 
          'verificationStatus', 'stock'
        ])
      );
      
      allow delete: if isAdmin();
    }

    // User Profiles
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(uid) && isValidUser(incoming()) && incoming().role in ['CUSTOMER', 'VENDOR']; 
      
      allow update: if isOwner(uid) && isValidUser(incoming()) && (
        incoming().role == existing().role &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email'])
      ) || isAdmin();
    }

    // User Cart (if managed in Firestore)
    match /users/{uid}/cart/{itemId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidCartItem(incoming());
      allow update: if isOwner(uid) && isValidCartItem(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['quantity'])
      );
      allow delete: if isOwner(uid);
    }
  }
}
