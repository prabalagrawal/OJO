rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens never contain custom claims in this env. Look up roles.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'prabalagrawal23@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      let requiredFields = ['email', 'role', 'displayName', 'createdAt'];
      return data.keys().hasAll(requiredFields) && 
             data.keys().size() == requiredFields.size() &&
             data.email == request.auth.token.email &&
             data.role in ['customer', 'admin'] &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      let requiredFields = ['name', 'price', 'origin', 'status'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.origin is string && data.origin.size() <= 100 &&
             data.status in ['pending', 'verified', 'live'] &&
             (data.get('category', '') is string) &&
             (data.get('description', '') is string) &&
             (data.get('artisanName', '') is string) &&
             (data.get('decisionTag', 'Most Trusted') in ['Most Trusted', 'Best for Gifting', 'Premium Pick']);
    }

    function isValidOrder(data) {
      let requiredFields = ['userId', 'total', 'status', 'items', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId == request.auth.uid &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0 &&
             data.createdAt == request.time;
    }

    function isValidActivityLog(data) {
      let requiredFields = ['event', 'userId', 'details', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.event is string &&
             data.userId == request.auth.uid &&
             data.timestamp == request.time;
    }

    // --- Collection Routes ---

    // Connection test document
    match /test/connection {
      allow read: if true; 
    }

    // Products Registry
    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true;
      
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      
      allow update: if (isAdmin() || (isSignedIn() && isEmailVerified())) && isValidId(productId) && isValidProduct(incoming()) && (
        isAdmin() || (
           // Only allow status updates for non-admins if they are vendors (future proofing) or limited fields
           incoming().diff(existing()).affectedKeys().hasOnly(['status']) && existing().status == 'pending'
        )
      );
      
      allow delete: if isAdmin() && isValidId(productId);
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().role == 'customer'; 
      
      allow update: if isValidId(userId) && (
        (isOwner(userId) && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])) || 
        isAdmin()
      );
    }

    // Orders
    match /orders/{orderId} {
      allow get: if isValidId(orderId) && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isEmailVerified() && isValidId(orderId) && isValidOrder(incoming());
      
      allow update: if isValidId(orderId) && (
        isAdmin() || (
          isOwner(existing().userId) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
          existing().status == 'pending' &&
          incoming().status == 'cancelled'
        )
      );
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow get: if isValidId(logId) && (isOwner(existing().userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(logId) && isValidActivityLog(incoming());
    }

    // Verification Logs
    match /verification_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && isValidId(logId);
    }
  }
}
