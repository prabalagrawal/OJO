{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Authentic artifact available in the registry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "images": { "type": "array" },
        "description": { "type": "string" },
        "origin": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "live"] },
        "vendor_id": { "type": "string" },
        "artisanName": { "type": "string" },
        "story": { "type": "string" },
        "category": { "type": "string" },
        "decisionTag": { "type": "string", "enum": ["Most Trusted", "Best for Gifting", "Premium Pick"] }
      },
      "required": ["name", "price", "origin", "status"]
    },
    "User": {
      "title": "User",
      "description": "System user including customers and admins.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase records.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "total", "status"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Audit trail for system events.",
      "type": "object",
      "properties": {
        "event": { "type": "string" },
        "userId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["event", "userId", "timestamp"]
    },
    "VerificationLog": {
      "title": "Verification Log",
      "description": "Logs for product verification actions.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "adminId": { "type": "string" },
        "status": { "type": "string" },
        "comments": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "adminId", "status", "timestamp"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Collection of verified artifacts" },
    "users": { "schema": "User", "description": "User profiles and roles" },
    "orders": { "schema": "Order", "description": "Orders and transactions" },
    "activity_logs": { "schema": "ActivityLog", "description": "System audit logs" },
    "verification_logs": { "schema": "VerificationLog", "description": "Product verification history" }
  }
}
